      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"engine\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"engine\"}[5m]))",
          "legendFormat": "error ratio"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "engine — p99 Latency (s)",
